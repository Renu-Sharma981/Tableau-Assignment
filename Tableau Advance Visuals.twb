            <groupfilter function='union' user:ui-action-filter='[Action1_C1266FCCDFCA42F59170FAA22CEC0C71]' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='crossjoin'>
