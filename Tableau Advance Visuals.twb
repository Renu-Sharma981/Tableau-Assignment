      </column>
      <column caption='Female Count' datatype='integer' name='[Calculation_0670485131956225]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Gender] = &quot;Female&quot; THEN 1 END' />
      </column>
      <column caption='Male (Left side)' datatype='integer' name='[Calculation_0670485134557186]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='- SUM([Calculation_0670485131771904])' />
      </column>
      <column caption='Female (Right side)' datatype='integer' name='[Calculation_0670485134688259]' role='measure' type='quantitative'>
